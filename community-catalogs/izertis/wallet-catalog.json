      "id": "identfy-personal-wallet",
      "name": "Identfy",
      "description": "Identfy Personal Wallet is Izertis' mobile wallet for end users, designed to manage verifiable credentials and interact with public and private digital services with a strong focus on privacy, usability and user control. The wallet supports secure reception and presentation of verifiable credentials through QR codes, deeplinks and proximity-based interactions, and includes advanced features such as credential filtering and search, customizable activations, visual alerts, biometric onboarding, document signing integrations with configurable QTSP/TSP providers, and enterprise-grade security mechanisms including PIN, biometrics, BIP-32 key management, backup and key recovery. It is multi-language, adaptable to corporate look and feel, agnostic to credential types and use cases, and compatible with European business wallets and identity ecosystems.",
      "type": "personal",
      "platforms": ["iOS", "Android"],
      "credentialFormats": ["SD-JWT-VC", "mDL/mDoc", "JWT-VC"],
      "issuanceProtocols": ["OpenID4VCI"],
      "presentationProtocols": ["OpenID4VP", "SIOPv2", "ISO 18013-5"],
      "supportedIdentifiers": ["did:key", "did:web", "did:isbe", "did:ebsi"],
      "keyStorage": ["Secure Enclave (iOS)","StrongBox (Android)","HSM"],
      "signingAlgorithms": ["ES256"],
      "credentialStatusMethods": ["BitstringStatusList v1.0"],
      "standards": ["W3C VC Data Model 2.0", "W3C DID Core v1.0"],
      "features": [
